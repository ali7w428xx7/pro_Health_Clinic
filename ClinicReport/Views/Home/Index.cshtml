@using ClinicReport.Models
@{
    ViewData["Title"] = "Dashboard";
    var stats = ViewBag.Stats as AppointmentStatsDto;
    var utilization = ViewBag.Utilization as List<DoctorUtilizationDto> ?? new();
    var cancellations = ViewBag.Cancellations as CancellationRateDto;
}

<h4 class="mb-4"><i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard</h4>

@if (stats != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small opacity-75">Total Appointments</div>
                            <div class="fs-3 fw-bold">@stats.TotalAppointments</div>
                        </div>
                        <i class="bi bi-calendar3 opacity-50" style="font-size:2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small opacity-75">Completed</div>
                            <div class="fs-3 fw-bold">@stats.Completed</div>
                        </div>
                        <i class="bi bi-check-circle opacity-50" style="font-size:2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-danger text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small opacity-75">Cancelled</div>
                            <div class="fs-3 fw-bold">@stats.Cancelled</div>
                        </div>
                        <i class="bi bi-x-circle opacity-50" style="font-size:2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="small opacity-75">Completion Rate</div>
                            <div class="fs-3 fw-bold">@stats.CompletionRate.ToString("F1")%</div>
                        </div>
                        <i class="bi bi-graph-up opacity-50" style="font-size:2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Monthly Appointments (Last 6 Months)</div>
                <div class="card-body">
                    <canvas id="monthlyChart" height="100"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">By Specialization</div>
                <div class="card-body">
                    <canvas id="specChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>
}

@if (utilization.Any())
{
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">Doctor Utilization Summary</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Doctor</th><th>Specializations</th><th>Booked / Slots</th><th>Utilization</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var d in utilization.Take(5))
                        {
                            <tr>
                                <td>@d.DoctorName</td>
                                <td class="text-muted small">@string.Join(", ", d.Specializations)</td>
                                <td>@d.BookedSlots / @d.TotalSlots</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:8px;">
                                            <div class="progress-bar @(d.UtilizationRate >= 75 ? "bg-success" : d.UtilizationRate >= 40 ? "bg-warning" : "bg-danger")"
                                                 style="width:@d.UtilizationRate%"></div>
                                        </div>
                                        <span class="small">@d.UtilizationRate.ToString("F0")%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (cancellations != null)
{
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm text-center">
                <div class="card-body py-4">
                    <div class="text-muted small mb-1">Overall Cancellation Rate</div>
                    <div class="display-5 fw-bold @(cancellations.OverallCancellationRate > 20 ? "text-danger" : "text-success")">
                        @cancellations.OverallCancellationRate.ToString("F1")%
                    </div>
                    <div class="text-muted small">@cancellations.TotalCancelled of @cancellations.TotalAppointments appointments</div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (stats != null && stats.MonthlyBreakdown.Any())
    {
        var monthly = stats.MonthlyBreakdown.TakeLast(6).ToList();
        var labels = string.Join(",", monthly.Select(m => $"\"{m.MonthName}\""));
        var totals = string.Join(",", monthly.Select(m => m.Total));
        var completedData = string.Join(",", monthly.Select(m => m.Completed));
        var cancelledData = string.Join(",", monthly.Select(m => m.Cancelled));
        var specLabels = string.Join(",", stats.BySpecialization.Select(s => $"\"{s.Specialization}\""));
        var specTotals = string.Join(",", stats.BySpecialization.Select(s => s.Total));

        <script>
            new Chart(document.getElementById('monthlyChart'), {
                type: 'bar',
                data: {
                    labels: [@Html.Raw(labels)],
                    datasets: [
                        { label: 'Total', data: [@Html.Raw(totals)], backgroundColor: 'rgba(13,110,253,0.6)' },
                        { label: 'Completed', data: [@Html.Raw(completedData)], backgroundColor: 'rgba(25,135,84,0.6)' },
                        { label: 'Cancelled', data: [@Html.Raw(cancelledData)], backgroundColor: 'rgba(220,53,69,0.6)' }
                    ]
                },
                options: { responsive: true, plugins: { legend: { position: 'top' } } }
            });

            new Chart(document.getElementById('specChart'), {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(specLabels)],
                    datasets: [{ data: [@Html.Raw(specTotals)], backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#0dcaf0','#6f42c1'] }]
                },
                options: { responsive: true }
            });
        </script>
    }
}
