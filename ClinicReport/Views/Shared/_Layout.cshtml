<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Clinic Reports</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { min-height: calc(100vh - 56px); background: #fff; border-right: 1px solid #dee2e6; }
        .sidebar .nav-link { color: #495057; border-radius: 0.375rem; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: #e9ecef; color: #0d6efd; }
        .sidebar .nav-link i { width: 20px; }
        .validation-summary-valid,
        .field-validation-valid {
            display: none;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-bar-chart-fill me-2"></i>Clinic Reports
            </a>
            @if (!string.IsNullOrEmpty(Context.Session.GetString("jwt")))
            {
                <div class="ms-auto d-flex align-items-center gap-2">
                    <span class="text-white small"><i class="bi bi-person-circle me-1"></i>@Context.Session.GetString("fullName")</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                    </form>
                </div>
            }
        </div>
    </nav>

    @if (!string.IsNullOrEmpty(Context.Session.GetString("jwt")))
    {
        <div class="container-fluid">
            <div class="row">
                <nav class="col-md-2 sidebar py-3 px-2">
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                        <li><hr class="my-1" /></li>
                        <li class="nav-item">
                            <a asp-controller="Reports" asp-action="Appointments"
                               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Appointments" ? "active" : "")">
                                <i class="bi bi-calendar3"></i> Appointments
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Reports" asp-action="DoctorUtilization"
                               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "DoctorUtilization" ? "active" : "")">
                                <i class="bi bi-person-check"></i> Doctor Utilization
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Reports" asp-action="CancellationRates"
                               class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "CancellationRates" ? "active" : "")">
                                <i class="bi bi-x-circle"></i> Cancellation Rates
                            </a>
                        </li>
                    </ul>
                </nav>
                <main class="col-md-10 py-4 px-4">
                    @if (TempData["Success"] != null)
                    { <div class="alert alert-success alert-dismissible py-2"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Success"]</div> }
                    @if (TempData["Error"] != null)
                    { <div class="alert alert-danger alert-dismissible py-2"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["Error"]</div> }
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        <div class="container mt-4">
            @RenderBody()
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
