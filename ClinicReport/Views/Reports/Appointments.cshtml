@model ClinicReport.Models.AppointmentStatsDto
@{ ViewData["Title"] = "Appointment Statistics"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-calendar3 text-primary me-2"></i>Appointment Statistics</h4>
</div>

<form method="get" class="card card-body shadow-sm mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">From Date</label>
            <input type="date" name="from" value="@ViewBag.From" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">To Date</label>
            <input type="date" name="to" value="@ViewBag.To" class="form-control" />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="Appointments" class="btn btn-outline-secondary ms-2">Clear</a>
        </div>
    </div>
</form>

@if (Model == null)
{
    <div class="alert alert-warning">Unable to load data from the API. Ensure ClinicAPI is running.</div>
    return;
}

<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total</div>
                <div class="fs-2 fw-bold text-primary">@Model.Total</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Completed</div>
                <div class="fs-2 fw-bold text-success">@Model.Completed</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Cancelled</div>
                <div class="fs-2 fw-bold text-danger">@Model.Cancelled</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Missed</div>
                <div class="fs-2 fw-bold text-warning">@Model.Missed</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Pending</div>
                <div class="fs-2 fw-bold text-info">@(Model.Requested + Model.Confirmed)</div>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Completion %</div>
                <div class="fs-2 fw-bold text-primary">@Model.CompletionRate.ToString("F1")%</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Monthly Trend</div>
            <div class="card-body">
                <canvas id="monthlyTrendChart" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">By Specialization</div>
            <div class="card-body">
                <canvas id="specPieChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

@if (Model.BySpecialization.Any())
{
    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Specialization Breakdown</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Specialization</th><th>Total Appointments</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.BySpecialization)
                    {
                        var pct = Model.Total > 0 ? (double)s.Total / Model.Total * 100 : 0;
                        <tr>
                            <td>@s.Name</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:8px;">
                                        <div class="progress-bar bg-primary" style="width:@pct%"></div>
                                    </div>
                                    <span class="small">@s.Total (@pct.ToString("F0")%)</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    @{
        var monthly = Model.ByMonth.TakeLast(12).ToList();
        var mLabels = string.Join(",", monthly.Select(m => $"\"{m.MonthName}\""));
        var mTotal = string.Join(",", monthly.Select(m => m.Total));
        var mCompleted = string.Join(",", monthly.Select(m => m.Completed));
        var mCancelled = string.Join(",", monthly.Select(m => m.Cancelled));
        var sLabels = string.Join(",", Model.BySpecialization.Select(s => $"\"{s.Name}\""));
        var sTotals = string.Join(",", Model.BySpecialization.Select(s => s.Total));
    }
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('monthlyTrendChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(mLabels)],
                datasets: [
                    { label: 'Total', data: [@Html.Raw(mTotal)], borderColor: '#0d6efd', tension: 0.3, fill: false },
                    { label: 'Completed', data: [@Html.Raw(mCompleted)], borderColor: '#198754', tension: 0.3, fill: false },
                    { label: 'Cancelled', data: [@Html.Raw(mCancelled)], borderColor: '#dc3545', tension: 0.3, fill: false }
                ]
            },
            options: { responsive: true, plugins: { legend: { position: 'top' } } }
        });

        new Chart(document.getElementById('specPieChart'), {
            type: 'pie',
            data: {
                labels: [@Html.Raw(sLabels)],
                datasets: [{ data: [@Html.Raw(sTotals)], backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#0dcaf0','#6f42c1','#fd7e14'] }]
            },
            options: { responsive: true }
        });
    </script>
}
