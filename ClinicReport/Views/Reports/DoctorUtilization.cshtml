@model List<ClinicReport.Models.DoctorUtilizationDto>
@{ ViewData["Title"] = "Doctor Utilization"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-person-check text-primary me-2"></i>Doctor Utilization</h4>
</div>

<form method="get" class="card card-body shadow-sm mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">From Date</label>
            <input type="date" name="from" value="@ViewBag.From" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">To Date</label>
            <input type="date" name="to" value="@ViewBag.To" class="form-control" />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary">Filter</button>
            <a asp-action="DoctorUtilization" class="btn btn-outline-secondary ms-2">Clear</a>
        </div>
    </div>
</form>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No utilization data available.</div>
    return;
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold">Utilization Chart</div>
    <div class="card-body">
        <canvas id="utilChart" height="80"></canvas>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header fw-semibold">Detailed Breakdown</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Doctor</th>
                        <th>Specializations</th>
                        <th>Completed Appts</th>
                        <th>Booked / Total Slots</th>
                        <th>Utilization</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.OrderByDescending(x => x.UtilizationRate))
                    {
                        <tr>
                            <td class="fw-semibold">@d.DoctorName</td>
                            <td class="text-muted small">@string.Join(", ", d.Specializations)</td>
                            <td>@d.CompletedAppointments</td>
                            <td>@d.CompletedAppointments / @d.TotalAppointments</td>
                            <td style="min-width:160px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height:10px;">
                                        <div class="progress-bar @(d.UtilizationRate >= 75 ? "bg-success" : d.UtilizationRate >= 40 ? "bg-warning" : "bg-danger")"
                                             style="width:@(Math.Min(d.UtilizationRate, 100))%"></div>
                                    </div>
                                    <span class="small fw-semibold">@d.UtilizationRate.ToString("F1")%</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    @{
        var names = string.Join(",", Model.Select(d => $"\"{d.DoctorName}\""));
        var rates = string.Join(",", Model.Select(d => d.UtilizationRate.ToString("F1")));
        var colors = string.Join(",", Model.Select(d =>
            d.UtilizationRate >= 75 ? "'rgba(25,135,84,0.7)'" :
            d.UtilizationRate >= 40 ? "'rgba(255,193,7,0.7)'" :
            "'rgba(220,53,69,0.7)'"));
    }
    <script>
        new Chart(document.getElementById('utilChart'), {
            type: 'bar',
            data: {
                labels: [@Html.Raw(names)],
                datasets: [{
                    label: 'Utilization %',
                    data: [@Html.Raw(rates)],
                    backgroundColor: [@Html.Raw(colors)]
                }]
            },
            options: {
                responsive: true,
                indexAxis: 'y',
                scales: { x: { max: 100, ticks: { callback: v => v + '%' } } },
                plugins: { legend: { display: false } }
            }
        });
    </script>
}
