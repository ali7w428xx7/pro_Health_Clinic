@model ClinicMVC.ViewModels.AppointmentDetailViewModel
@{ ViewData["Title"] = "Appointment Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-calendar2-check text-primary me-2"></i>Appointment Details</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light fw-semibold">Appointment Info</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Date</dt><dd class="col-7">@Model.AppointmentDate.ToString("dd MMMM yyyy")</dd>
                    <dt class="col-5">Time</dt><dd class="col-7">@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</dd>
                    <dt class="col-5">Specialization</dt><dd class="col-7">@Model.SpecializationName</dd>
                    <dt class="col-5">Status</dt>
                    <dd class="col-7">
                        @{
                            var badge = Model.Status switch {
                                ClinicAPI.Models.AppointmentStatus.Completed => "bg-success",
                                ClinicAPI.Models.AppointmentStatus.Cancelled => "bg-secondary",
                                ClinicAPI.Models.AppointmentStatus.Missed => "bg-danger",
                                ClinicAPI.Models.AppointmentStatus.InProgress => "bg-warning text-dark",
                                ClinicAPI.Models.AppointmentStatus.CheckedIn => "bg-info text-dark",
                                ClinicAPI.Models.AppointmentStatus.Confirmed => "bg-primary",
                                _ => "bg-light text-dark border"
                            };
                        }
                        <span class="badge @badge fs-6">@Model.Status</span>
                    </dd>
                    <dt class="col-5">Reason</dt><dd class="col-7">@Model.ReasonForVisit</dd>
                    @if (!string.IsNullOrEmpty(Model.CancellationReason))
                    { <dt class="col-5">Cancelled Reason</dt><dd class="col-7 text-danger">@Model.CancellationReason</dd> }
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light fw-semibold">People</div>
            <div class="card-body">
                <p class="mb-1"><strong>Patient:</strong> @Model.PatientName <span class="text-muted small">(@Model.PatientCPR)</span></p>
                <p class="mb-0"><strong>Doctor:</strong> @Model.DoctorName</p>
            </div>
        </div>
    </div>
</div>

<!-- Action Buttons -->
<div class="mt-3 d-flex flex-wrap gap-2">
    @if (Model.Status == ClinicAPI.Models.AppointmentStatus.Requested && (User.IsInRole("Receptionist") || User.IsInRole("ClinicManager")))
    {
        <form asp-action="Confirm" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check-circle me-1"></i>Confirm</button>
        </form>
    }
    @if (Model.Status == ClinicAPI.Models.AppointmentStatus.Confirmed && (User.IsInRole("Receptionist") || User.IsInRole("ClinicManager")))
    {
        <form asp-action="CheckIn" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-info btn-sm text-white"><i class="bi bi-door-open me-1"></i>Check In</button>
        </form>
        <form asp-action="MarkMissed" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning btn-sm"><i class="bi bi-x-circle me-1"></i>Mark Missed</button>
        </form>
    }
    @if (Model.Status == ClinicAPI.Models.AppointmentStatus.CheckedIn && (User.IsInRole("Doctor") || User.IsInRole("ClinicManager")))
    {
        <form asp-action="StartConsultation" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-play-circle me-1"></i>Start Consultation</button>
        </form>
    }
    @if (Model.Status == ClinicAPI.Models.AppointmentStatus.InProgress && (User.IsInRole("Doctor") || User.IsInRole("ClinicManager")))
    {
        <a asp-action="Complete" asp-route-id="@Model.Id" class="btn btn-success btn-sm"><i class="bi bi-check2-all me-1"></i>Complete & Record</a>
    }
    @if ((Model.Status == ClinicAPI.Models.AppointmentStatus.Requested || Model.Status == ClinicAPI.Models.AppointmentStatus.Confirmed))
    {
        <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-x-lg me-1"></i>Cancel</a>
    }
</div>

<!-- Visit Record -->
@if (Model.VisitRecord != null)
{
    <div class="card mt-4 shadow-sm">
        <div class="card-header bg-success text-white fw-semibold"><i class="bi bi-clipboard2-pulse me-2"></i>Visit Record</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-md-3">Doctor Notes</dt><dd class="col-md-9">@Model.VisitRecord.DoctorNotes</dd>
                <dt class="col-md-3">Diagnosis</dt><dd class="col-md-9">@Model.VisitRecord.Diagnosis</dd>
                <dt class="col-md-3">Treatment Plan</dt><dd class="col-md-9">@Model.VisitRecord.TreatmentPlan</dd>
            </dl>
        </div>
    </div>

    <div class="card mt-3 shadow-sm">
        <div class="card-header bg-light fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-capsule me-2"></i>Prescriptions (@Model.Prescriptions.Count)</span>
            @if (User.IsInRole("Doctor") || User.IsInRole("ClinicManager"))
            {
                <a asp-action="AddPrescription" asp-route-visitRecordId="@Model.VisitRecord.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus me-1"></i>Add</a>
            }
        </div>
        <div class="card-body">
            @if (Model.Prescriptions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>Medication</th><th>Dosage</th><th>Frequency</th><th>Duration</th><th>Notes</th></tr></thead>
                        <tbody>
                            @foreach (var p in Model.Prescriptions)
                            {
                                <tr>
                                    <td>@p.MedicationName</td>
                                    <td>@p.Dosage</td>
                                    <td>@p.Frequency</td>
                                    <td>@p.Duration</td>
                                    <td class="text-muted small">@p.SpecialInstructions</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else { <p class="text-muted mb-0">No prescriptions recorded.</p> }
        </div>
    </div>
}
