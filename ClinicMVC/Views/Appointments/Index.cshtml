    @model ClinicMVC.ViewModels.AppointmentListViewModel
@{ ViewData["Title"] = "Appointments"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-calendar-check text-primary me-2"></i>Appointments</h4>
    @if (User.IsInRole("Patient") || User.IsInRole("Receptionist") || User.IsInRole("ClinicManager"))
    {
        <a asp-action="Book" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>Book New</a>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetNames<ClinicAPI.Models.AppointmentStatus>())
            { <option value="@s" selected="@(Model.StatusFilter == s)">@s</option> }
        </select>
    </div>
    <div class="col-md-3">
        <input type="date" name="from" class="form-control form-control-sm" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" placeholder="From" />
    </div>
    <div class="col-md-3">
        <input type="date" name="to" class="form-control form-control-sm" value="@Model.DateTo?.ToString("yyyy-MM-dd")" placeholder="To" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-outline-secondary btn-sm me-1"><i class="bi bi-funnel me-1"></i>Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
    </div>
</form>

<p class="text-muted small">Showing @Model.Appointments.Count of @Model.TotalCount appointments</p>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>Date</th><th>Time</th><th>Patient</th><th>Doctor</th><th>Specialization</th><th>Status</th><th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Appointments)
            {
                <tr>
                    <td>@a.AppointmentDate.ToString("dd MMM yyyy")</td>
                    <td>@a.StartTime.ToString(@"hh\:mm")</td>
                    <td>@a.PatientName<br /><small class="text-muted">@a.PatientCPR</small></td>
                    <td>@a.DoctorName</td>
                    <td>@a.SpecializationName</td>
                    <td>
                        @{
                            var badge = a.Status switch {
                                ClinicAPI.Models.AppointmentStatus.Completed => "bg-success",
                                ClinicAPI.Models.AppointmentStatus.Cancelled => "bg-secondary",
                                ClinicAPI.Models.AppointmentStatus.Missed => "bg-danger",
                                ClinicAPI.Models.AppointmentStatus.InProgress => "bg-warning text-dark",
                                ClinicAPI.Models.AppointmentStatus.CheckedIn => "bg-info text-dark",
                                ClinicAPI.Models.AppointmentStatus.Confirmed => "bg-primary",
                                _ => "bg-light text-dark border"
                            };
                        }
                        <span class="badge @badge">@a.Status</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-outline-primary btn-sm">View</a>
                    </td>
                </tr>
            }
            @if (!Model.Appointments.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No appointments found.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-status="@Model.StatusFilter">@i</a>
                </li>
            }
        </ul>
    </nav>
}
