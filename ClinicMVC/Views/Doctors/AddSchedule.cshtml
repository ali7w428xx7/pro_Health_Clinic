@model ClinicMVC.ViewModels.AddScheduleViewModel
@{ ViewData["Title"] = "Add Schedule"; }

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white"><i class="bi bi-calendar-plus me-2"></i>Add Schedule</div>
            <div class="card-body p-4">
                <form asp-action="AddSchedule" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="DoctorId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="DayOfWeek" class="form-label"></label>
                            <select asp-for="DayOfWeek" asp-items="Html.GetEnumSelectList<DayOfWeek>()" class="form-select"></select>
                            <span asp-validation-for="DayOfWeek" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label"></label>
                            <input asp-for="StartTime" class="form-control" type="time" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label"></label>
                            <input asp-for="EndTime" class="form-control" type="time" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="SlotDurationMinutes" class="form-label"></label>
                            <select asp-for="SlotDurationMinutes" class="form-select">
                                <option value="15">15 minutes</option>
                                <option value="20">20 minutes</option>
                                <option value="30" selected>30 minutes</option>
                                <option value="45">45 minutes</option>
                                <option value="60">60 minutes</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success mt-3 w-100"><i class="bi bi-plus me-1"></i>Add Schedule</button>
                    <a asp-action="Details" asp-route-id="@Model.DoctorId" class="btn btn-outline-secondary mt-2 w-100">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
