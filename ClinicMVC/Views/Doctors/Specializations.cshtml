@model IEnumerable<ClinicMVC.ViewModels.SpecializationViewModel>
@{ ViewData["Title"] = "Specializations"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tags text-primary me-2"></i>Specializations</h4>
    <a asp-action="CreateSpecialization" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle me-1"></i>New</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light"><tr><th>Name</th><th>Description</th><th>Doctors</th></tr></thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@s.Name</td>
                            <td class="text-muted small">@s.Description</td>
                            <td><span class="badge bg-info">@s.DoctorCount</span></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    { <tr><td colspan="3" class="text-muted text-center py-4">No specializations yet.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
