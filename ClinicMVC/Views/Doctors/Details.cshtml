@model ClinicMVC.ViewModels.DoctorDetailViewModel
@{ ViewData["Title"] = "Doctor Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-person-badge text-primary me-2"></i>@Model.FullName</h4>
    <div class="btn-group btn-group-sm">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="AddSchedule" asp-route-doctorId="@Model.Id" class="btn btn-outline-success">Add Schedule</a>
        <a asp-action="AddLeave" asp-route-doctorId="@Model.Id" class="btn btn-outline-warning">Add Leave</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Profile</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">License</dt><dd class="col-7">@Model.LicenseNumber</dd>
                    <dt class="col-5">Email</dt><dd class="col-7 text-break">@Model.Email</dd>
                    <dt class="col-5">Status</dt>
                    <dd class="col-7"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "Active" : "Inactive")</span></dd>
                    <dt class="col-5">Appts</dt><dd class="col-7">@Model.TotalAppointments</dd>
                    @if (!string.IsNullOrEmpty(Model.Bio))
                    { <dt class="col-5">Bio</dt><dd class="col-7 text-muted small">@Model.Bio</dd> }
                </dl>
            </div>
        </div>
        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold d-flex justify-content-between">
                <span>Specializations</span>
                <a asp-action="Specializations" class="btn btn-link btn-sm p-0">Manage All</a>
            </div>
            <div class="card-body">
                @if (Model.Specializations.Any())
                {
                    @foreach (var s in Model.Specializations)
                    { <span class="badge bg-info me-1 mb-1">@s</span> }
                }
                else { <span class="text-muted small">None assigned.</span> }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Weekly Schedule</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>Day</th><th>Start</th><th>End</th><th>Slot</th><th>Status</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var s in Model.Schedules)
                            {
                                <tr>
                                    <td>@s.DayOfWeek</td>
                                    <td>@s.StartTime.ToString(@"hh\:mm")</td>
                                    <td>@s.EndTime.ToString(@"hh\:mm")</td>
                                    <td>@s.SlotDurationMinutes min</td>
                                    <td><span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Off")</span></td>
                                    <td>
                                        <form asp-action="DeleteSchedule" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@s.Id" />
                                            <input type="hidden" name="doctorId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm py-0">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Schedules.Any())
                            { <tr><td colspan="6" class="text-muted text-center py-2">No schedule set.</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-light fw-semibold">Leave Periods</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light"><tr><th>From</th><th>To</th><th>Reason</th><th>Approved</th></tr></thead>
                        <tbody>
                            @foreach (var l in Model.LeavePeriods)
                            {
                                <tr>
                                    <td>@l.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@l.EndDate.ToString("dd MMM yyyy")</td>
                                    <td>@l.Reason</td>
                                    <td><span class="badge @(l.IsApproved ? "bg-success" : "bg-warning text-dark")">@(l.IsApproved ? "Yes" : "Pending")</span></td>
                                </tr>
                            }
                            @if (!Model.LeavePeriods.Any())
                            { <tr><td colspan="4" class="text-muted text-center py-2">No leave periods.</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>
