@using ClinicAPI.DTOs
@model PublicLookupResultDto
@{ ViewData["Title"] = "Your Appointments"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-9">
        <div class="alert alert-success"><i class="bi bi-person-check me-2"></i>Results for: <strong>@Model.PatientName</strong></div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white"><i class="bi bi-calendar-check me-2"></i>Upcoming Appointments</div>
            <div class="card-body">
                @if (Model.UpcomingAppointments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light"><tr><th>Date</th><th>Time</th><th>Doctor</th><th>Specialization</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var a in Model.UpcomingAppointments)
                                {
                                    <tr>
                                        <td>@a.AppointmentDate.ToString("dd MMM yyyy")</td>
                                        <td>@a.StartTime.ToString(@"hh\:mm")</td>
                                        <td>@a.DoctorName</td>
                                        <td>@a.SpecializationName</td>
                                        <td><span class="badge bg-primary">@a.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else { <p class="text-muted mb-0">No upcoming appointments.</p> }
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white"><i class="bi bi-clock-history me-2"></i>Recent Visit Summary</div>
            <div class="card-body">
                @if (Model.RecentVisits.Any())
                {
                    @foreach (var v in Model.RecentVisits)
                    {
                        <div class="border rounded p-3 mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <strong>@v.AppointmentDate.ToString("dd MMM yyyy")</strong>
                                <span class="text-muted small">@v.DoctorName &mdash; @v.SpecializationName</span>
                            </div>
                            <p class="mb-1"><strong>Diagnosis:</strong> @v.Diagnosis</p>
                            <p class="mb-0"><strong>Treatment:</strong> @v.TreatmentPlan</p>
                        </div>
                    }
                }
                else { <p class="text-muted mb-0">No recent visits on record.</p> }
            </div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>New Search</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary ms-2"><i class="bi bi-box-arrow-in-right me-1"></i>Login for Full Access</a>
    </div>
</div>
